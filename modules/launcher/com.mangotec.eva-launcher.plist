<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.mangotec.eva-launcher</string>

  <key>ProgramArguments</key>
  <array>
    <string>/usr/bin/python3</string>
    <string>/Users/REPLACE_USERNAME/Eva/modules/launcher/eva_launcher.py</string>
  </array>

  <key>WorkingDirectory</key>
  <string>/Users/REPLACE_USERNAME/Eva/modules/launcher</string>

  <key>RunAtLoad</key>
  <true/>

  <key>KeepAlive</key>
  <true/>

  <key>StandardOutPath</key>
  <string>/Users/REPLACE_USERNAME/Eva/logs/launcher.log</string>

  <key>StandardErrorPath</key>
  <string>/Users/REPLACE_USERNAME/Eva/logs/launcher.error.log</string>

  <key>EnvironmentVariables</key>
  <dict>
    <key>PATH</key>
    <string>/usr/local/bin:/usr/bin:/bin:/opt/homebrew/bin</string>
  </dict>
</dict>
</plist>
