# ─────────────────────────────────────────────
#  EVA DB Stack — Environment Variables
#  Copy to .env and fill in values
#  NEVER commit .env to GitHub
# ─────────────────────────────────────────────

# PostgreSQL
POSTGRES_PASSWORD=eva_local_secret

# ArcadeDB
ARCADEDB_PASSWORD=eva_local_secret

# Qdrant (local = no key needed, cloud = paste key here)
QDRANT_API_KEY=
QDRANT_URL=http://localhost:6333

# When moving to Qdrant Cloud, swap these:
# QDRANT_URL=https://your-cluster.qdrant.io
# QDRANT_API_KEY=your_cloud_api_key
